{
  "metadata": {
    "version": "1.0",
    "platform": "Shadiro Event Services",
    "created": "2026-02-09",
    "status": "Active",
    "description": "Premium, modern design system for Shadiro event platform (Web + Mobile)"
  },
  "colorSystem": {
    "primary": {
      "name": "Deep Rose / Wine",
      "hex": "#BE185D",
      "rgb": "190, 24, 93",
      "usage": "Primary CTAs, headers, key interactions",
      "variants": {
        "50": "#FCE7F3",
        "100": "#FBCFE8",
        "200": "#F8AADE",
        "300": "#F472B6",
        "400": "#EC4899",
        "500": "#BE185D",
        "600": "#9D174D",
        "700": "#831843",
        "800": "#500724"
      }
    },
    "secondary": {
      "name": "Charcoal",
      "hex": "#1F2937",
      "rgb": "31, 41, 55",
      "usage": "Text, dark backgrounds, secondary elements",
      "variants": {
        "50": "#F9FAFB",
        "100": "#F3F4F6",
        "200": "#E5E7EB",
        "300": "#D1D5DB",
        "400": "#9CA3AF",
        "500": "#6B7280",
        "600": "#4B5563",
        "700": "#374151",
        "800": "#1F2937",
        "900": "#111827"
      }
    },
    "accent": {
      "name": "Gold",
      "hex": "#F59E0B",
      "rgb": "245, 158, 11",
      "usage": "Highlights, premium features, success states",
      "variants": {
        "50": "#FFFBEB",
        "100": "#FEF3C7",
        "200": "#FDE68A",
        "300": "#FCD34D",
        "400": "#FBBF24",
        "500": "#F59E0B",
        "600": "#D97706",
        "700": "#B45309",
        "800": "#92400E"
      }
    },
    "background": {
      "name": "Soft White",
      "hex": "#FAFAFA",
      "rgb": "250, 250, 250",
      "usage": "Page backgrounds, light surfaces"
    },
    "semanticColors": {
      "success": "#10B981",
      "error": "#EF4444",
      "warning": "#F59E0B",
      "info": "#3B82F6",
      "neutral": "#6B7280"
    },
    "gradients": {
      "premiumHero": "linear-gradient(135deg, #BE185D 0%, #9D174D 100%)",
      "goldAccent": "linear-gradient(135deg, #F59E0B 0%, #D97706 100%)",
      "subtle": "linear-gradient(180deg, #FAFAFA 0%, #F3F4F6 100%)"
    }
  },
  "typography": {
    "fontFamily": {
      "primary": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
      "secondary": "'Poppins', sans-serif"
    },
    "scales": {
      "h1": {
        "size": "32px",
        "weight": 700,
        "lineHeight": "40px",
        "letterSpacing": "-0.5px",
        "usage": "Page titles, hero headlines"
      },
      "h2": {
        "size": "24px",
        "weight": 700,
        "lineHeight": "32px",
        "usage": "Section headers"
      },
      "h3": {
        "size": "20px",
        "weight": 600,
        "lineHeight": "28px",
        "usage": "Subsection headers, card titles"
      },
      "h4": {
        "size": "18px",
        "weight": 600,
        "lineHeight": "24px",
        "usage": "Minor headers"
      },
      "body": {
        "size": "16px",
        "weight": 400,
        "lineHeight": "24px",
        "usage": "Main content, descriptions"
      },
      "bodySmall": {
        "size": "14px",
        "weight": 400,
        "lineHeight": "20px",
        "usage": "Secondary text, metadata"
      },
      "caption": {
        "size": "12px",
        "weight": 500,
        "lineHeight": "16px",
        "usage": "Labels, badges, helper text"
      }
    }
  },
  "spacing": {
    "scale": {
      "0": "0px",
      "1": "4px",
      "2": "8px",
      "3": "12px",
      "4": "16px",
      "5": "20px",
      "6": "24px",
      "7": "28px",
      "8": "32px",
      "9": "36px",
      "10": "40px",
      "12": "48px",
      "14": "56px",
      "16": "64px"
    },
    "padding": {
      "container": "16px",
      "card": "20px",
      "section": "24px"
    },
    "margin": {
      "sectionGap": "32px",
      "componentGap": "16px"
    }
  },
  "borderRadius": {
    "sm": "8px",
    "md": "12px",
    "lg": "16px",
    "xl": "20px",
    "full": "999px"
  },
  "shadows": {
    "none": "none",
    "sm": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
    "md": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06)",
    "lg": "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05)",
    "xl": "0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04)",
    "2xl": "0 25px 50px -12px rgba(0, 0, 0, 0.25)",
    "premium": "0 20px 25px -5px rgba(190, 24, 93, 0.15)"
  },
  "transitions": {
    "fast": "150ms ease-out",
    "standard": "250ms ease-out",
    "slow": "350ms ease-out",
    "smooth": "cubic-bezier(0.4, 0, 0.2, 1)"
  },
  "components": {
    "button": {
      "variants": {
        "primary": {
          "background": "#BE185D",
          "text": "#FFFFFF",
          "padding": "12px 24px",
          "fontSize": "16px",
          "fontWeight": 600,
          "borderRadius": "12px",
          "shadow": "md",
          "hover": {
            "background": "#9D174D",
            "shadow": "lg",
            "transform": "translateY(-2px)"
          },
          "active": {
            "background": "#831843",
            "transform": "translateY(0)"
          },
          "disabled": {
            "background": "#9CA3AF",
            "cursor": "not-allowed",
            "opacity": 0.6
          }
        },
        "secondary": {
          "background": "#F3F4F6",
          "text": "#1F2937",
          "border": "1px solid #D1D5DB",
          "padding": "12px 24px",
          "fontSize": "16px",
          "fontWeight": 600,
          "borderRadius": "12px",
          "hover": {
            "background": "#E5E7EB",
            "borderColor": "#9CA3AF"
          }
        },
        "outline": {
          "background": "transparent",
          "text": "#BE185D",
          "border": "2px solid #BE185D",
          "padding": "10px 22px",
          "fontSize": "16px",
          "fontWeight": 600,
          "borderRadius": "12px",
          "hover": {
            "background": "#FCE7F3"
          }
        },
        "icon": {
          "background": "transparent",
          "padding": "8px",
          "borderRadius": "8px",
          "hover": {
            "background": "#F3F4F6"
          }
        }
      },
      "sizes": {
        "sm": {
          "padding": "8px 16px",
          "fontSize": "14px"
        },
        "md": {
          "padding": "12px 24px",
          "fontSize": "16px"
        },
        "lg": {
          "padding": "16px 32px",
          "fontSize": "18px"
        }
      }
    },
    "card": {
      "background": "#FFFFFF",
      "borderRadius": "16px",
      "padding": "20px",
      "shadow": "md",
      "border": "1px solid #F3F4F6",
      "hover": {
        "shadow": "lg",
        "transition": "all 250ms ease-out"
      }
    },
    "input": {
      "background": "#FFFFFF",
      "border": "1px solid #D1D5DB",
      "borderRadius": "12px",
      "padding": "12px 16px",
      "fontSize": "16px",
      "focus": {
        "borderColor": "#BE185D",
        "outline": "none",
        "boxShadow": "0 0 0 3px rgba(190, 24, 93, 0.1)"
      },
      "disabled": {
        "background": "#F3F4F6",
        "color": "#9CA3AF"
      }
    },
    "badge": {
      "padding": "6px 12px",
      "borderRadius": "999px",
      "fontSize": "12px",
      "fontWeight": 600,
      "variants": {
        "primary": {
          "background": "#FCE7F3",
          "color": "#BE185D"
        },
        "success": {
          "background": "#ECFDF5",
          "color": "#10B981"
        },
        "warning": {
          "background": "#FFFBEB",
          "color": "#F59E0B"
        },
        "gold": {
          "background": "#FFFBEB",
          "color": "#D97706"
        }
      }
    }
  },
  "layouts": {
    "mobileBottomTabs": {
      "height": "64px",
      "background": "#FFFFFF",
      "borderTop": "1px solid #E5E7EB",
      "items": 5,
      "tabs": [
        {
          "icon": "home",
          "label": "Home",
          "path": "/"
        },
        {
          "icon": "search",
          "label": "Search",
          "path": "/vendors"
        },
        {
          "icon": "calendar",
          "label": "Bookings",
          "path": "/bookings"
        },
        {
          "icon": "message",
          "label": "Chat",
          "path": "/chat"
        },
        {
          "icon": "user",
          "label": "Profile",
          "path": "/profile"
        }
      ]
    },
    "webSidebar": {
      "width": "280px",
      "background": "#FFFFFF",
      "borderRight": "1px solid #E5E7EB",
      "items": [
        {
          "icon": "dashboard",
          "label": "Dashboard",
          "path": "/"
        },
        {
          "icon": "store",
          "label": "Vendors",
          "path": "/vendors"
        },
        {
          "icon": "calendar",
          "label": "Bookings",
          "path": "/bookings"
        },
        {
          "icon": "message",
          "label": "Chat",
          "path": "/chat"
        },
        {
          "icon": "creditCard",
          "label": "Payments",
          "path": "/payments"
        },
        {
          "icon": "user",
          "label": "Profile",
          "path": "/profile"
        }
      ]
    }
  }
}
