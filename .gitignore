# ═══════════════════════════════════════════════════════════════════════════════
# Shadiro Monorepo — .gitignore
# ═══════════════════════════════════════════════════════════════════════════════

# ── IDE & Editors ─────────────────────────────────────────────────────────────
.idea/
.vscode/
.continue/
*.swp
*.swo
*~

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
/.pnp
.pnp.js
.yarn/install-state.gz
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyc
venv/
.venv/
*.egg-info/
.eggs/
pip-log.txt

# ── Environment Files ─────────────────────────────────────────────────────────
# CRITICAL: Never commit .env files with real credentials
*.env
*.env.*
!*.env.example
**/.env

# ── Secrets & Credentials ────────────────────────────────────────────────────
*token.json*
*credentials.json*
*.pem
*.key

# ── Testing ───────────────────────────────────────────────────────────────────
/coverage
.pytest_cache/
test_reports/
htmlcov/
.coverage
.coverage.*

# ── Build Outputs ─────────────────────────────────────────────────────────────
/build
dist/
/.next/
/out/
next-env.d.ts
*.tsbuildinfo

# ── Logs & Temporary Files ───────────────────────────────────────────────────
logs/
*.log
*.tmp
*.bak
*.cache
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dump.rdb

# ── System Files ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── Development Tools ────────────────────────────────────────────────────────
chainlit.md
.chainlit
.ipynb_checkpoints/
.ac

# ── Deployment ────────────────────────────────────────────────────────────────
.vercel

# ── Data & Databases ─────────────────────────────────────────────────────────
agenthub/agents/youtube/db

# ── Archive & Large Assets ───────────────────────────────────────────────────
**/*.zip
**/*.tar.gz
**/*.tar
**/*.tgz
*.pack
*.deb
*.dylib

# ── Build Caches ─────────────────────────────────────────────────────────────
.cache/

# ── Mobile Development ───────────────────────────────────────────────────────
android-sdk/
.expo/

# ── Project-specific Artifacts ───────────────────────────────────────────────
memory/
backend.worktrees/
backend/venv/
