APP_NAME=Shadiro API
APP_ENV=development
LOG_LEVEL=INFO

# MongoDB Atlas format:
# mongodb+srv://<db-user>:<password>@<cluster-host>/shadiro?retryWrites=true&w=majority
MONGO_URL=mongodb://localhost:27017/shadiro
DB_NAME=shadiro
MONGO_MIN_POOL_SIZE=5
MONGO_MAX_POOL_SIZE=100
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000

# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=paste_64_char_random_value_generated_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

ALLOWED_ORIGINS=https://shadiro.com,https://www.shadiro.com,http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
CORS_ORIGINS=https://shadiro.com,https://www.shadiro.com,http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
REQUEST_MAX_BODY_SIZE_BYTES=2097152

REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_AUTH_BURST=5
RATE_LIMIT_PUBLIC_PER_MINUTE=120
RATE_LIMIT_PUBLIC_BURST=40
RATE_LIMIT_BURST_WINDOW_SECONDS=10

RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=razorpay_webhook_secret
RAZORPAY_PAYOUT_ACCOUNT_NUMBER=

RESEND_API_KEY=
CLOUDINARY_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
