# Core
BASE_URL=http://127.0.0.1:8000
LOAD_MODE=steady
K6_SUMMARY_PATH=backend/loadtests/k6/output/summary.json

# Auth
USER_TOKEN=replace_with_user_jwt
ADMIN_TOKEN=replace_with_admin_jwt
USER_AUTH_SCHEME=Bearer
ADMIN_AUTH_SCHEME=Bearer

# Endpoint paths (override only if needed)
VENDOR_LIST_PATH=/api/vendors?limit=20
BOOKING_CREATE_PATH=/api/bookings
PAYMENT_CONFIRM_PATH=/api/payments/verify
ADMIN_PATH=/api/admin/analytics

# Booking payload
BOOKING_VENDOR_ID=replace_with_vendor_id
BOOKING_EVENT_ID=
BOOKING_EVENT_DATE=2026-12-31
BOOKING_CITY=Mumbai
BOOKING_LOCATION=Mumbai

# Payment payload
PAYMENT_ORDER_ID=replace_with_internal_order_id
RAZORPAY_ORDER_ID=replace_with_razorpay_order_id
RAZORPAY_PAYMENT_ID=replace_with_razorpay_payment_id
RAZORPAY_SIGNATURE=replace_with_razorpay_signature

# Steady mode
STEADY_RPS=50
STEADY_DURATION=10m

# Spike mode
SPIKE_BASE_RPS=30
SPIKE_PEAK_RPS=180
SPIKE_HOLD=2m

# Soak mode
SOAK_RPS=40
SOAK_DURATION=2h
